 <% layout("/layouts/boilerplate") -%>


<div class="container-fluid py-5">

  <div class="orders-wrapper">

    <!-- 🔥 TOP SECTION -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">

      <div class="d-flex align-items-center">
        <div class="orders-title">Your Orders</div>

        <div class="orders-count">
          <%= orders.length %>
        </div>
      </div>

      <select class="form-select filter-select">
        <option>Past 3 Month</option>
        <option>2026</option>
        <option>2025</option>
      </select>

    </div>

    <!-- 🔥 TABS -->
    <div class="custom-tabs mb-4">

      <button class="btn active-tab">
        Orders
      </button>

      <button class="btn">
        Not Yet Shipped
      </button>

      <button class="btn">
        Cancelled Orders
      </button>

    </div>

    <% if (orders.length === 0) { %>

      <div class="bg-white rounded-4 p-5 text-center border">
        <h4>No Orders Yet</h4>

        <a href="/products" class="btn buy-btn mt-3">
          Shop Now
        </a>
      </div>

    <% } else { %>

      <% orders.forEach(order => { %>

        <div class="order-card">

          <!-- 🔥 HEADER -->
          <div class="order-header">

            <div class="row align-items-start">

              <div class="col-lg-2 col-md-6">
                <div class="header-label">
                  Order placed
                </div>

                <div class="header-value">
                  <%= order.createdAt.toDateString() %>
                </div>
              </div>

              <div class="col-lg-2 col-md-6">
                <div class="header-label">
                  Total
                </div>

                <div class="header-value">
                  ₹<%= order.totalPrice.toFixed(2) %>
                </div>
              </div>

              <div class="col-lg-3 col-md-6">
                <div class="header-label">
                  Ship to
                </div>

                <div class="header-value">
                  <%= order.user?.username || "Customer" %>
                </div>
              </div>

              <div class="col-lg-5 col-md-6 text-lg-end">

                <div class="order-number mb-2">
                  Order # <%= order._id %>
                </div>

                <div class="d-flex justify-content-lg-end gap-4 flex-wrap">

                  <a href="#" class="order-link">
                    View order details
                  </a>

                  <a href="#" class="order-link">
                    View invoice
                  </a>

                </div>

              </div>

            </div>

          </div>

          <!-- 🔥 PAID BOX -->
          <div class="paid-box">

            <div class="paid-left">

              <div class="paid-icon">
                ★
              </div>

              <div>
                Payment Status :
                <strong><%= order.status %></strong>
              </div>

            </div>

            <div style="font-size:22px; cursor:pointer;">
              ×
            </div>

          </div>

          <!-- 🔥 PRODUCTS -->
          <div class="product-section">

            <% order.products.forEach(item => { %>

              <div class="delivery-title">
                Delivered
              </div>

              <div class="delivery-sub">
                Your package was delivered successfully.
              </div>

              <div class="product-box">

                <!-- LEFT -->
                <div class="product-left">

                  <img 
                    src="<%= item.product.image %>" 
                    class="product-img"
                  >

                  <div>

                    <div class="product-title">
                      <%= item.product.title %>
                    </div>

                    <div class="product-return">
                      Qty: <%= item.quantity %>
                    </div>

                  </div>

                </div>

                <!-- RIGHT -->
                <div class="d-flex align-items-center gap-2 flex-wrap w-auto">

                  <a 
                    href="/order/buy/<%= item.product._id %>" 
                    class="btn buy-btn"
                  >
                    ↻ Buy it again
                  </a>

                  <a 
                    href="/products/<%= item.product._id %>" 
                    class="btn view-btn"
                  >
                    View your item
                  </a>

                  <button class="btn track-btn">
                    Track package
                  </button>

                  <button class="menu-btn">
                    ⋯
                  </button>

                </div>

              </div>

              <% if(order.products.length > 1){ %>
                <hr class="mt-4">
              <% } %>

            <% }) %>

          </div>

        </div>

      <% }) %>

    <% } %>

  </div>

</div>